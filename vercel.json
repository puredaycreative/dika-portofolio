{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://andhika-porto-sendiri.vercel.app/$1",
      "permanent": true
    }
  ],
  "builds": [
    { "src": "server_production.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "server_production.js" }
  ]
}